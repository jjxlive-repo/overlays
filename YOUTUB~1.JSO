{
  "_note": "YouTube Super Sticker image URLs captured from live sticker picker. Animated WebP (=s200-rwa) are what SSN sends as contentimg. Static previews (=s200-rp) are used as pack tab thumbnails. SSN delivers the exact URL per sticker dynamically — our gift-bar uses data.contentimg directly so no manual lookup is needed.",
  "_packs_identified": [
    "Flowstate (teal bird character) — $2–$50",
    "Blue alien / hippo character (Game Over, Next Time) — $2+",
    "Shiba Inu dog (Hows It Going, Bye Bye) — $2–$3",
    "Diverse people stickers (I'll Be Back, ME!, Rock hand) — $2–$3",
    "Lemon / yellow stick figure (dancing, wand) — $2–$3",
    "Icon/text stickers (Thumbs Up, On Set, Vlog, Thanks, Unboxing, Sneak Peek) — $1.99",
    "Food/object stickers (Unicorn, Peach, Salt, NOPE, Rainbow, Hotdog) — $1.49",
    "Giant emoji stickers (😁😉😎❤️💲💩) — $0.99",
    "Gaming robot stickers (GG, GLHF, NOOB, TRY AGAIN, CRITICAL) — $2–$5"
  ],
